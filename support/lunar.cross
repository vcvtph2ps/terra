[host_machine]
system = 'lunar'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = 'x86_64-lunar-gcc'
cpp = 'x86_64-lunar-g++'
ar = 'x86_64-lunar-ar'
strip = 'x86_64-lunar-strip'
ld = 'x86_64-lunar-ld'
[built-in options]
c_args = ['-march=x86-64', '-mabi=sysv']
cpp_args = ['-march=x86-64', '-mabi=sysv']
