source/limine {
    url: "https://github.com/Limine-Bootloader/Limine/releases/download/v12.4.0/limine-binary.tar.xz"
    type: "tar.xz"
    b2sum: "d04b4709e91f2181f18f9f6e6e1fdcc5ace5075424f7d7aa88c3431db6f3695b26d5eecd1a7baff53dfca76819af8cad441b55db60336845ad4c5201f127519c"
}

tool/limine {
    dependencies: [ source/limine image/clang image/lld image/make ]
    build: <sh>
        cc -g -O2 -pipe -std=c99 $SOURCES_DIR/limine/limine.c -o limine
    </sh>
    install: <sh>
        install -D limine $INSTALL_DIR$PREFIX/bin/limine
    </sh>
}
